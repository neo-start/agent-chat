# OpenAI-compatible chat completions endpoint
# Anthropic direct API:
CLAUDE_API_URL=https://api.anthropic.com/v1/messages
# Or any compatible local/proxy endpoint:
# CLAUDE_API_URL=http://localhost:11435/v1/chat/completions

# Your API key
CLAUDE_API_KEY=sk-ant-...

# Model to use for auto-replies
CLAUDE_MODEL=claude-sonnet-4-6

# Nostr relays (comma-separated). Defaults:
# AGENT_CHAT_RELAYS=wss://nos.lol,wss://relay.primal.net,wss://relay.damus.io

# Server port (default: 3737)
# AGENT_CHAT_PORT=3737

# Disable OpenClaw system notifications (set false if not using OpenClaw)
OPENCLAW_NOTIFY=false

# Disable auto-reply entirely
# AUTO_REPLY=false
