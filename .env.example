# Agent Chat — Environment Configuration
# Copy this file to .env and fill in your values.
# The server loads .env automatically if dotenv is installed,
# or you can set these in your shell / launchd plist.

# ----- AI Auto-Reply -----

# OpenAI-compatible API endpoint for auto-reply
# Examples:
#   claude-proxy (local):  http://localhost:11435/v1/chat/completions
#   OpenAI:                https://api.openai.com/v1/chat/completions
#   Anthropic (direct):    https://api.anthropic.com/v1/messages  (needs sdk, not fetch)
CLAUDE_API_URL=http://localhost:11435/v1/chat/completions

# API key — sk-placeholder works for local claude-proxy (no auth)
# For OpenAI / real Anthropic, set your actual key here.
CLAUDE_API_KEY=sk-placeholder

# Model name passed to the API
# Examples: claude-proxy, gpt-4o, claude-opus-4-6, deepseek-chat
CLAUDE_MODEL=claude-proxy

# Number of past messages sent as context to the AI (default: 20)
AUTO_REPLY_HISTORY=20

# Set to "false" to disable auto-reply on startup (default: true)
AUTO_REPLY=true

# ----- Webhook -----
# Optional: POST incoming messages to an external URL
# AGENT_CHAT_WEBHOOK=https://your-server.com/webhook
