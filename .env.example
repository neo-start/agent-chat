# Agent Chat — Environment Configuration
# Copy this file to .env and fill in your values.
# The server loads .env automatically at startup (no extra dependencies).
# You can also set these in your shell / launchd plist / systemd unit.

# ----- Server -----

# HTTP + WebSocket port (default: 3737)
# AGENT_CHAT_PORT=3737

# Local data directory for identity, contacts, and messages (default: ~/.agent-chat)
# AGENT_CHAT_DATA_DIR=/home/user/.agent-chat

# ----- Nostr Relays -----

# Comma-separated list of relay WebSocket URLs
# Default: wss://nos.lol,wss://relay.primal.net,wss://relay.damus.io
# AGENT_CHAT_RELAYS=wss://nos.lol,wss://relay.primal.net,wss://relay.damus.io

# ----- AI Auto-Reply -----

# OpenAI-compatible API endpoint
# Examples:
#   claude-proxy (local):  http://localhost:11435/v1/chat/completions  ← default
#   OpenAI:                https://api.openai.com/v1/chat/completions
#   Ollama:                http://localhost:11434/v1/chat/completions
#   DeepSeek:              https://api.deepseek.com/v1/chat/completions
# CLAUDE_API_URL=http://localhost:11435/v1/chat/completions

# API key (sk-placeholder works for local claude-proxy with no auth)
# CLAUDE_API_KEY=sk-placeholder

# Model name passed to the API
# Examples: claude-proxy, gpt-4o, claude-opus-4-6, deepseek-chat, llama3
# CLAUDE_MODEL=claude-proxy

# Number of past messages sent as context (default: 20)
# AUTO_REPLY_HISTORY=20

# Set to "false" to disable auto-reply on startup (default: true)
# AUTO_REPLY=true

# ----- Notifications -----

# Set to "false" to disable openclaw system event notifications (default: true)
# Safe to leave as-is on machines without openclaw — it auto-detects and silences.
# OPENCLAW_NOTIFY=true

# Optional: POST incoming messages to an external URL
# AGENT_CHAT_WEBHOOK=https://your-server.com/webhook
